# ─── THE SCRIPTORIUM — ENVIRONMENT VARIABLES ─────────────────────────────────
# Copy this file to .env.local and fill in your values.
# Never commit .env.local to git.

# ─── SIGNAL INK — Email delivery for reader questions ─────────────────────────
# Sign up at resend.com (free tier: 100 emails/day — more than enough for Phase 1)
RESEND_API_KEY=re_your_api_key_here

# The author's email — where Signal Ink questions are delivered
SIGNAL_TO_EMAIL=author@yourdomain.com

# The sending address — must be verified in Resend
# For Phase 1, you can use: onboarding@resend.dev (Resend's test address)
SIGNAL_FROM_EMAIL=signal@thescriptorium.com

# ─── PHASE 2 (not needed yet) ─────────────────────────────────────────────────
# NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
# CLERK_SECRET_KEY=
# DATABASE_URL=
# REDIS_URL=
# NEXT_PUBLIC_SANITY_PROJECT_ID=
# SANITY_API_TOKEN=
# STRIPE_SECRET_KEY=
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
